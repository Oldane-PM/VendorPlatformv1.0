SUPABASE_SERVICE_ROLE_KEY=

# App (browser + server URLs for links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth — set the SITE origin only (no path). Routes live at /api/auth/* via basePath in code.
# Prefer: https://YOUR-SERVICE.up.railway.app
# Not this (redundant): https://YOUR-SERVICE.up.railway.app/api/auth
# If you include /api/auth by mistake, auth.ts still normalizes to the origin.
# Google OAuth redirect URI is different — that MUST be the full callback URL, e.g.:
#   https://YOUR-SERVICE.up.railway.app/api/auth/callback/google
BETTER_AUTH_URL=http://localhost:3000
# Required in production: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Optional: extra origins (comma-separated) if you use multiple public URLs
# BETTER_AUTH_TRUSTED_ORIGINS=https://app.example.com,https://staging.example.com
# Railway also injects RAILWAY_PUBLIC_DOMAIN — auth.ts uses it to avoid 401 when env is mis-set

# Email (Resend)
RESEND_API_KEY=re_QtmaQ3KT_GkJGqzHKDuUSFGSi3dNiDohM
RESEND_DOMAIN=example.com

# Upload Security
UPLOAD_TOKEN_PEPPER=change-me-to-a-random-secret
